<section class="page-banner">
  <div class="container">
    <h1>联系我们</h1>
    <p>期待与您合作</p>
  </div>
</section>
<section class="contact-section section">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-info">
        <h2>联系方式</h2>
        <div class="contact-item"><h3>联系电话</h3><p>400-888-8888</p><p>138-0000-0000</p></div>
        <div class="contact-item"><h3>微信</h3><p>特色蛋品行</p></div>
        <div class="contact-item"><h3>地址</h3><p>中国优质农产品供应基地</p></div>
        <div class="contact-item"><h3>营业时间</h3><p>周一至周六 8:00 - 18:00</p></div>
      </div>
      <div class="contact-form-wrap">
        <h2>在线留言</h2>
        <form action="/contact" method="POST" class="contact-form">
          <div class="form-group"><label>姓名</label><input type="text" name="name" class="form-input" placeholder="请输入姓名"></div>
          <div class="form-group"><label>电话</label><input type="tel" name="phone" class="form-input" placeholder="请输入电话"></div>
          <div class="form-group"><label>留言</label><textarea name="message" class="form-input form-textarea" rows="4" placeholder="请描述您的需求"></textarea></div>
          <button type="submit" class="btn btn-primary">提交留言</button>
        </form>
      </div>
    </div>
  </div>
</section>