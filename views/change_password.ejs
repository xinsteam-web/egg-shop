<section class="page-banner">
  <div class="container">
    <h1>修改密码</h1>
    <p>安全设置</p>
  </div>
</section>
<section class="form-page section">
  <div class="container">
    <div class="form-card">
      <% if (error) { %><div class="form-error"><%= error %></div><% } %>
      <% if (success) { %><div class="form-success"><%= success %></div><% } %>
      <form action="/password" method="POST">
        <div class="form-group">
          <label>当前密码</label>
          <input type="password" name="current_password" required class="form-input" placeholder="请输入当前密码">
        </div>
        <div class="form-group">
          <label>新密码</label>
          <input type="password" name="new_password" required class="form-input" placeholder="请输入新密码（至少4位）">
        </div>
        <div class="form-group">
          <label>确认新密码</label>
          <input type="password" name="confirm_password" required class="form-input" placeholder="请再次输入新密码">
        </div>
        <button type="submit" class="btn btn-primary btn-block">确认修改</button>
      </form>
      <p class="form-footer"><a href="/">返回首页</a></p>
    </div>
  </div>
</section>