<section class="page-banner">
  <div class="container">
    <h1>注册</h1>
    <p>注册批发客户账号</p>
  </div>
</section>
<section class="form-page section">
  <div class="container">
    <div class="form-card">
      <% if (error) { %><div class="form-error"><%= error %></div><% } %>
      <form action="/register" method="POST">
        <div class="form-group">
          <label>用户名 *</label>
          <input type="text" name="username" required class="form-input" placeholder="请输入登录用户名">
        </div>
        <div class="form-group">
          <label>密码 *</label>
          <input type="password" name="password" required class="form-input" placeholder="请输入密码">
        </div>
        <div class="form-group">
          <label>企业名称 *</label>
          <input type="text" name="company" required class="form-input" placeholder="请输入企业/店铺名称">
        </div>
        <div class="form-group">
          <label>联系人 *</label>
          <input type="text" name="contact" required class="form-input" placeholder="请输入联系人姓名">
        </div>
        <div class="form-group">
          <label>联系电话 *</label>
          <input type="tel" name="phone" required class="form-input" placeholder="请输入联系电话">
        </div>
        <div class="form-group">
          <label>地址</label>
          <input type="text" name="address" class="form-input" placeholder="请输入收货地址（选填）">
        </div>
        <button type="submit" class="btn btn-primary btn-block">注册</button>
      </form>
      <p class="form-footer">已有账号？<a href="/login">立即登录</a></p>
    </div>
  </div>
</section>
